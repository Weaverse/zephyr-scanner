---
import Default from "../../layouts/Default.astro";

const title = "Zephyr vs Shopify Commerce Readiness — Compare";
const description =
  "Shopify's Commerce Readiness tool scores Liquid storefronts in one shot. Zephyr adds headless/Hydrogen depth, scores agentic-commerce protocols, and re-checks over time. An honest comparison.";
const canonical = "https://zephyr.build/compare/shopify-commerce-readiness";

const rows = [
  { feature: "Free, no signup", zephyr: true, them: true },
  { feature: "Works on classic Liquid storefronts", zephyr: true, them: true },
  {
    feature: "Headless / Hydrogen-aware checks",
    zephyr: "Built for it",
    them: "Assumes hosted theme",
  },
  {
    feature: "Scores agentic-commerce protocols (UCP, MCP, ACP, x402, WebMCP)",
    zephyr: "Scored, with verified-live spec briefs",
    them: "Partial",
  },
  {
    feature: "Per-check remediation hints",
    zephyr: "Every failing check",
    them: "Ranks gaps, doesn't fix",
  },
  {
    feature: "Re-scan over time + email on score change",
    zephyr: "Weekly change-detection",
    them: false,
  },
  { feature: "Embeddable badge", zephyr: true, them: false },
  { feature: "Open source", zephyr: true, them: false },
];
---

<Default
  title={title}
  description={description}
  ogUrl={canonical}
  canonical={canonical}
>
  <section class="max-w-3xl mx-auto px-6 py-12">
    <p class="text-sm font-mono uppercase tracking-wide text-zephyr-500 mb-3">
      Comparison
    </p>
    <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-zephyr-900 mb-4">
      Zephyr vs Shopify Commerce Readiness
    </h1>
    <p class="text-lg text-zephyr-700 mb-6">
      Shopify quietly shipped its own scanner at
      <code class="font-mono text-sm">commerce-readiness.shopify.io</code> — 31
      checks across five categories, free, no login. It's a solid diagnostic. But
      it's built for the classic hosted-theme world and stops at the snapshot.
      Here's where Zephyr goes further. <span class="text-zephyr-500"
        >(Comparison reflects public information as of May 2026.)</span
      >
    </p>

    <div class="overflow-x-auto rounded-lg border border-zephyr-100 bg-white">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-zephyr-100 text-left">
            <th class="px-4 py-3 font-semibold text-zephyr-900"></th>
            <th class="px-4 py-3 font-semibold text-zephyr-600">Zephyr</th>
            <th class="px-4 py-3 font-semibold text-zephyr-700">
              Shopify Commerce Readiness
            </th>
          </tr>
        </thead>
        <tbody>
          {
            rows.map((r) => (
              <tr class="border-b border-zephyr-50 last:border-0 align-top">
                <td class="px-4 py-3 text-zephyr-700">{r.feature}</td>
                <td class="px-4 py-3 text-zephyr-900">
                  {r.zephyr === true
                    ? "✓"
                    : r.zephyr === false
                      ? "—"
                      : r.zephyr}
                </td>
                <td class="px-4 py-3 text-zephyr-700">
                  {r.them === true ? "✓" : r.them === false ? "—" : r.them}
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <div class="prose prose-zephyr mt-10">
      <h2 class="text-2xl font-bold text-zephyr-900 mb-3">
        Where Shopify's tool is great
      </h2>
      <p class="text-zephyr-700">
        If you run a standard Shopify theme, Shopify's scanner is the most native
        read you can get — it knows the platform's own structured-data output and
        flags the universal misses (absent llms.txt, incomplete product JSON-LD,
        thin policy pages) that fail on nearly every store. Start there if that's
        you.
      </p>

      <h2 class="text-2xl font-bold text-zephyr-900 mt-8 mb-3">
        Where Zephyr is the better fit
      </h2>
      <ul class="text-zephyr-700 list-disc pl-6 space-y-2">
        <li>
          <strong>You're headless / Hydrogen.</strong> Once you decouple the
          storefront, robots, sitemaps, JSON-LD, and protocol endpoints become
          your app's responsibility. Zephyr checks that headless reality instead
          of assuming the platform serves it.
        </li>
        <li>
          <strong>You care about agent commerce protocols.</strong> Zephyr scores
          UCP, MCP server cards, ACP, x402, and WebMCP against spec briefs
          verified against live implementations.
        </li>
        <li>
          <strong>You want to track drift.</strong> A score is a moment in time;
          a deploy can break it. Subscribe and Zephyr re-scans weekly and emails
          you when your grade moves.
        </li>
      </ul>
    </div>

    <div class="mt-10 rounded-lg bg-zephyr-900 p-8 text-center text-white">
      <p class="text-lg font-semibold mb-4">
        Scan your store and see your commerce-readiness score.
      </p>
      <a
        href="/"
        class="inline-block rounded-lg bg-white px-6 py-3 font-medium text-zephyr-900 hover:bg-zephyr-50"
      >
        Run a free scan →
      </a>
    </div>
  </section>
</Default>
