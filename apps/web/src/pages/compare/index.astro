---
import Default from "../../layouts/Default.astro";

const title = "Zephyr vs other agent-readiness scanners — Compare";
const description =
  "How Zephyr compares to Shopify's Commerce Readiness tool and Cloudflare's Agent Readiness scanner for AI-commerce readiness — especially on headless and agentic-commerce protocols.";
const canonical = "https://zephyr.build/compare";

const comparisons = [
  {
    href: "/compare/shopify-commerce-readiness",
    name: "Shopify Commerce Readiness",
    blurb:
      "Shopify's own scanner is Shopify-native and one-shot. See where it stops — headless depth, protocol scoring, and re-scan-over-time.",
  },
  {
    href: "/compare/cloudflare-agent-readiness",
    name: "Cloudflare Agent Readiness",
    blurb:
      "Cloudflare scores 50+ general signals but doesn't count commerce protocols toward your score. See where commerce depth diverges.",
  },
];
---

<Default
  title={title}
  description={description}
  ogUrl={canonical}
  canonical={canonical}
>
  <section class="max-w-3xl mx-auto px-6 py-16">
    <h1 class="text-4xl font-bold tracking-tight text-zephyr-900 mb-4">
      How Zephyr compares
    </h1>
    <p class="text-lg text-zephyr-700 mb-10">
      A few good agent-readiness scanners exist now. Zephyr is the one built for
      commerce depth — it scores agentic-commerce protocols, understands headless
      Hydrogen storefronts, and re-checks over time instead of giving a one-shot
      snapshot. Honest breakdowns below.
    </p>
    <div class="space-y-4">
      {
        comparisons.map((c) => (
          <a
            href={c.href}
            class="block border border-zephyr-100 rounded-lg bg-white p-6 hover:border-zephyr-300"
          >
            <h2 class="text-xl font-semibold text-zephyr-900 mb-1">
              Zephyr vs {c.name} →
            </h2>
            <p class="text-sm text-zephyr-700">{c.blurb}</p>
          </a>
        ))
      }
    </div>
  </section>
</Default>
